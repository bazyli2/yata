# Shared environment reference for the yata starter.
# Per-app env files (backend/.env and frontend/.env.local) are auto-seeded
# from their own .example files by the devbox init hook.

# Backend
DATABASE_URL=postgresql+psycopg://postgres@localhost:5432/app
CORS_ORIGINS=["http://localhost:3000"]

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
